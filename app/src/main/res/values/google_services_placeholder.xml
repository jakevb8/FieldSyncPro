<?xml version="1.0" encoding="utf-8"?>
<!--
  Placeholder for the Google Sign-In web client ID.
  The real value is auto-generated by the google-services plugin once
  google-services.json contains an OAuth web client (client_type 3).
  Steps to populate:
    1. Enable Google Sign-In in Firebase Console → Authentication → Sign-in method
    2. Add your debug SHA-1 in Firebase Console → Project Settings → Android app
    3. Re-download google-services.json and update the GOOGLE_SERVICES_JSON GitHub secret
-->
<resources>
    <string name="default_web_client_id" translatable="false"></string>
</resources>
